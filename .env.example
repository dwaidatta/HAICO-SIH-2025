# Copy this to .env and fill in your values
# Load with: export $(cat .env | xargs)  OR use python-dotenv

# ── Polaris ────────────────────────────────────────────────────────────────
POLARIS_CLANG="~/Polaris-Obfuscator/src/build/bin/clang"
POLARIS_PASSES="fla,gvenc,indcall,indbr,alias,bcf,sub,mba"
COMPILE_FLAGS="-O0"

# ── Gemini ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.0-flash"

# ── Flask ──────────────────────────────────────────────────────────────────
FLASK_HOST="127.0.0.1"
FLASK_PORT=5000
FLASK_DEBUG=true
UPLOAD_FOLDER="./uploads"
JOB_TIMEOUT=120